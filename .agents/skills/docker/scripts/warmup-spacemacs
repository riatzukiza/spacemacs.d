#!/usr/bin/env bash
set -euo pipefail

export DISPLAY="${DISPLAY:-:99}"
export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/tmp/runtime-agent}"
export EMACS_DAEMON_NAME="warmup"
mkdir -p "$XDG_RUNTIME_DIR"

# Start a temporary Xvfb so Spacemacs can warm packages headlessly.
Xvfb "$DISPLAY" -screen 0 1600x1000x24 -nolisten tcp >/tmp/warmup-xvfb.log 2>&1 &
XVFB_PID=$!
cleanup() { kill "$XVFB_PID" >/dev/null 2>&1 || true; }
trap cleanup EXIT

for _ in $(seq 1 50); do
  xdpyinfo -display "$DISPLAY" >/dev/null 2>&1 && break
  sleep 0.1
done
if ! xdpyinfo -display "$DISPLAY" >/dev/null 2>&1; then
  echo "Xvfb did not become ready on $DISPLAY" >&2
  exit 1
fi

# Start a foreground daemon.  This initializes Spacemacs and installs
# declared packages.  A hard timeout prevents the build from hanging.
emacs --fg-daemon="$EMACS_DAEMON_NAME" >/tmp/warmup-emacs.log 2>&1 &
EMACS_PID=$!

ready() {
  emacsclient -s "$EMACS_DAEMON_NAME" -e 't' >/dev/null 2>&1
}

for _ in $(seq 1 300); do
  ready && break
  if ! kill -0 "$EMACS_PID" >/dev/null 2>&1; then
    echo "Emacs warmup daemon exited early" >&2
    exit 1
  fi
  sleep 1
done

if ! ready; then
  echo "Emacs warmup daemon did not become ready" >&2
  kill "$EMACS_PID" >/dev/null 2>&1 || true
  exit 1
fi

# Best-effort refresh of package archives to capture the latest metadata,
# then shut the daemon down cleanly.
emacsclient -s "$EMACS_DAEMON_NAME" -e '(progn (ignore-errors (package-refresh-contents)) (kill-emacs))' || true
wait "$EMACS_PID" >/dev/null 2>&1 || true
