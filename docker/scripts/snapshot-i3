#!/usr/bin/env bash
set -euo pipefail
out_dir="${1:-/workspace/.artifacts/i3}"
mkdir -p "$out_dir"
ts="$(date +%Y%m%d-%H%M%S)"
i3-msg -t get_tree > "$out_dir/tree-$ts.json"
i3-msg -t get_workspaces > "$out_dir/workspaces-$ts.json"
printf '%s\n' "$out_dir/tree-$ts.json" "$out_dir/workspaces-$ts.json"
